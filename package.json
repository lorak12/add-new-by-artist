{
  "name": "add-new-by-artist",
  "version": "1.0.0",
  "description": "Spicetify extension — finds missing songs from an artist and adds them to your library",
  "type": "module",
  "scripts": {
    "build": "node --loader ts-node/esm scripts/build.ts",
    "watch": "node --loader ts-node/esm scripts/watch.ts",
    "dev": "npm run watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
